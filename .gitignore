# Logs & Cache CodeIgniter
writable/cache/*
writable/codeigniter-debugbar/*
writable/debugbar/*
writable/logs/*
writable/session/*
writable/uploads/*

# Abaikan file upload/log tetapi pertahankan foldernya
!writable/cache/.gitkeep
!writable/codeigniter-debugbar/.gitkeep
!writable/debugbar/.gitkeep
!writable/logs/.gitkeep
!writable/session/.gitkeep
!writable/uploads/.gitkeep

